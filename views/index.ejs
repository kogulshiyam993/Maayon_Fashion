<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Maayon Fashion - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <h1>Style Meets <span>Excellence</span></h1>
            <p class="lead">Discover trendy fashion and premium stationery, crafted for those who appreciate quality.</p>
            <a href="/products/fashion" class="btn-gold">EXPLORE COLLECTION</a>
        </div>
    </section>

    <!-- Fashion Products -->
    <section class="featured-section">
        <div class="container">
            <h2 class="section-title">Trendy Girls' Fashion</h2>
            <p class="section-subtitle">Handpicked styles for every occasion</p>
            <div class="row g-4">
                <% if (fashionProducts && fashionProducts.length > 0) { %>
                    <% fashionProducts.forEach(product => { %>
                        <div class="col-md-4 col-lg-3">
                            <div class="product-card">
                                <div class="product-img-wrap">
                                    <img src="<%= product.image_url %>" class="product-img" alt="<%= product.name %>">
                                </div>
                                <div class="product-info">
                                    <h5><%= product.name %></h5>
                                    <div class="price">LKR <%= product.price %></div>
                                    <a href="/product/<%= product.id %>" class="btn-outline-gold w-100 text-center d-block">View Details</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-center">No fashion products available yet.</p>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Stationery Products -->
    <section class="featured-section bg-light">
        <div class="container">
            <h2 class="section-title">Premium Stationery</h2>
            <p class="section-subtitle">Quality essentials for creativity</p>
            <div class="row g-4">
                <% if (stationeryProducts && stationeryProducts.length > 0) { %>
                    <% stationeryProducts.forEach(product => { %>
                        <div class="col-md-4 col-lg-3">
                            <div class="product-card">
                                <div class="product-img-wrap">
                                    <img src="<%= product.image_url %>" class="product-img" alt="<%= product.name %>">
                                </div>
                                <div class="product-info">
                                    <h5><%= product.name %></h5>
                                    <div class="price">LKR <%= product.price %></div>
                                    <a href="/product/<%= product.id %>" class="btn-outline-gold w-100 text-center d-block">View Details</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-center">No stationery products available yet.</p>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Newsletter Section -->
    <section class="newsletter-section">
        <div class="container">
            <h3>Join the Family</h3>
            <p>Subscribe for exclusive offers and style inspiration</p>
            <form class="newsletter-input-group" action="/subscribe" method="POST">
                <input type="email" name="email" class="form-control" placeholder="Your email address" required>
                <button type="submit" class="btn-gold">Subscribe</button>
            </form>
        </div>
    </section>

    <%- include('partials/footer') %>
    
    <!-- Admin FAB -->
    <a href="/auth/login" class="admin-fab">
        <span class="lock-icon">🔒</span>
        <span>Admin</span>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>