<nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">
        <a class="navbar-brand" href="/">
            <span class="brand-gold">MAAYON</span>
            <span class="brand-rose">FASHION</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link <%= locals.currentPage === 'home' ? 'active' : '' %>" href="/">Home</a>
                </li>

                <!-- Dynamic Categories -->
                <% (locals.categories || []).forEach(cat => { %>
                    <li class="nav-item">
                        <a class="nav-link <%= locals.currentPage === cat.slug ? 'active' : '' %>"
                           href="/products/<%= cat.slug %>"><%= cat.name %></a>
                    </li>
                <% }) %>

                <li class="nav-item">
                    <a class="nav-link <%= locals.currentPage === 'about' ? 'active' : '' %>" href="/about">About Us</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= locals.currentPage === 'reviews' ? 'active' : '' %>" href="/reviews">Reviews</a>
                </li>
                <% if (locals.isAdmin) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/dashboard">
                            <i class="fas fa-cog"></i> Admin
                        </a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>
