<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - MAAYON FASHION</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background: linear-gradient(135deg, #f2e0dc 0%, #fdf6f3 60%, #ffffff 100%);
        }
        .auth-card {
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.09);
            padding: 44px 40px;
        }
        .auth-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--gold);
        }
        .auth-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.75rem;
            color: var(--dark);
            margin: 6px 0 6px;
        }
        .auth-subtitle {
            color: var(--mid);
            font-size: 0.88rem;
        }
        .form-label {
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--dark);
            margin-bottom: 6px;
        }
        .form-control {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 0.93rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-control:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(196,160,80,0.12);
            outline: none;
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6 col-lg-5">
                    <div class="auth-card">

                        <!-- Brand Header -->
                        <div class="text-center mb-4">
                            <p class="auth-brand mb-1">Maayon Fashion</p>
                            <h2 class="auth-title">Reset Password</h2>
                            <p class="auth-subtitle">Enter your email and we'll send you a reset link.</p>
                        </div>

                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2" role="alert" style="border-radius:10px;font-size:0.88rem;">
                                <i class="fas fa-exclamation-circle"></i>
                                <%= error %>
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                            </div>
                        <% } %>

                        <% if (typeof success !== 'undefined' && success) { %>
                            <div class="alert d-flex align-items-center gap-2" role="alert"
                                 style="background:#f0faf4;border:1px solid #b6e9cc;color:#1a6b3c;border-radius:10px;font-size:0.88rem;">
                                <i class="fas fa-check-circle"></i>
                                <%= success %>
                            </div>
                        <% } %>

                        <form action="/auth/forgot-password" method="POST">
                            <div class="mb-4">
                                <label for="email" class="form-label">Email Address</label>
                                <input type="email" class="form-control" id="email" name="email"
                                       placeholder="you@example.com" required autofocus>
                            </div>

                            <button type="submit" class="btn btn-gold w-100 mb-3" style="padding:11px;font-size:0.95rem;">
                                Send Reset Link
                            </button>
                        </form>

                        <hr style="border-color:var(--border);margin:20px 0;">

                        <div class="text-center">
                            <a href="/auth/login" class="text-decoration-none"
                               style="color:var(--mid);font-size:0.88rem;">
                                <i class="fas fa-arrow-left me-1" style="font-size:0.75rem;"></i> Back to Login
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
