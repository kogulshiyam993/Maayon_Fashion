<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Page Header -->
<div style="background:linear-gradient(135deg,var(--rose) 0%,#fdf6f3 100%);padding:50px 0 40px;text-align:center;">
    <div class="container">
        <p style="font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;">Collection</p>
        <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);margin-bottom:10px;"><%= locals.categoryName || category %></h1>
        <p style="color:var(--mid);font-size:0.95rem;">Explore our <%= locals.categoryName || category %> collection</p>
    </div>
</div>

<div class="container my-5">
    <% if (products && products.length > 0) { %>
        <!-- Count -->
        <p style="color:var(--mid);font-size:0.85rem;margin-bottom:24px;">
            Showing <strong><%= products.length %></strong> item<%= products.length !== 1 ? 's' : '' %>
        </p>
        <div class="row">
            <% products.forEach(product => { %>
                <div class="col-md-4 col-sm-6 mb-4">
                    <div class="product-card">
                        <div class="product-img-wrap">
                            <img src="<%= product.image_url %>" class="product-img" alt="<%= product.name %>">
                        </div>
                        <div class="product-info">
                            <span class="product-tag" style="font-size:0.65rem;padding:3px 10px;"><%= product.category %></span>
                            <h5 class="mt-2"><%= product.name %></h5>
                            <p class="price">LKR <%= product.price %></p>
                            <a href="/product/<%= product.id %>" class="btn btn-outline-gold w-100">View Details</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x mb-3" style="color:var(--rose-dark);"></i>
            <h3 style="font-family:'Playfair Display',serif;color:var(--mid);">No products yet</h3>
            <p style="color:var(--mid);">Check back soon — new arrivals coming!</p>
            <a href="/" class="btn btn-gold mt-2">Back to Home</a>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
