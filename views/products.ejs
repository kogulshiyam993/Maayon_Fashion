<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 section-title"><%= locals.categoryName || category %></h1>
        <p class="lead text-muted">Explore our <%= locals.categoryName || category %> collection</p>
    </div>

    <% if (products && products.length > 0) { %>
        <div class="row">
            <% products.forEach(product => { %>
                <div class="col-md-4 mb-4">
                    <div class="product-card">
                        <img src="<%= product.image_url %>" class="product-img" alt="<%= product.name %>">
                        <div class="product-info">
                            <h5><%= product.name %></h5>
                            <p class="price">LKR <%= product.price %></p>
                            <a href="/product/<%= product.id %>" class="btn btn-outline-gold">View Details</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h3 class="text-muted">No products available yet</h3>
            <p class="text-muted">Check back soon!</p>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
