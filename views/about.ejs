<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Page Header -->
<div style="background:linear-gradient(135deg,var(--rose) 0%,#fdf6f3 100%);padding:60px 0 50px;text-align:center;">
    <div class="container">
        <p style="font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;">Est. 2024</p>
        <h1 style="font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.2rem);margin-bottom:12px;">Our Story</h1>
        <p style="color:var(--mid);font-size:1rem;max-width:520px;margin:0 auto;">Where elegance meets everyday life — a story woven with passion, purpose, and pride.</p>
    </div>
</div>

<!-- Anniversary Banner -->
<div style="background:linear-gradient(90deg,var(--gold) 0%,#e8c878 100%);padding:16px 0;text-align:center;">
    <p style="margin:0;color:#fff;font-family:'Playfair Display',serif;font-size:1.1rem;letter-spacing:1px;">
        <i class="fas fa-crown me-2"></i> Celebrating Our 1st Anniversary of Excellence <i class="fas fa-crown ms-2"></i>
    </p>
</div>

<div class="container my-5">

    <!-- Brand Story -->
    <div class="row justify-content-center mb-5">
        <div class="col-lg-7 text-center">
            <p style="font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;">The Beginning</p>
            <h2 style="font-family:'Playfair Display',serif;font-size:clamp(1.4rem,3vw,2rem);margin-bottom:20px;">A Dream Stitched Into Reality</h2>
            <p style="color:var(--mid);line-height:1.9;font-size:0.97rem;margin-bottom:16px;">
                From a dream to a destination — MAAYON FASHION was born from a deep love for style,
                quality, and community. In one short year, we have grown into a trusted name for
                girls' fashion and premium stationery, serving customers who value both beauty and craftsmanship.
            </p>
            <p style="color:var(--mid);line-height:1.9;font-size:0.97rem;">
                We are a small business with a big heart. Every piece in our collection is handpicked
                with care — chosen not just for its appearance, but for the joy it brings to the
                people who wear it or use it every day.
            </p>
        </div>
    </div>

    <!-- Values Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div style="background:#fff;border:1px solid var(--border);border-radius:14px;padding:32px 24px;text-align:center;height:100%;box-shadow:0 2px 12px rgba(0,0,0,0.04);">
                <div style="width:60px;height:60px;background:var(--rose);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
                    <i class="fas fa-heart" style="color:var(--rose-dark);font-size:1.4rem;"></i>
                </div>
                <h5 style="font-family:'Playfair Display',serif;margin-bottom:10px;">Made With Love</h5>
                <p style="color:var(--mid);font-size:0.9rem;line-height:1.75;margin:0;">Every product is selected with genuine care for our customers. We treat each order as a personal gift from us to you.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div style="background:#fff;border:1px solid var(--border);border-radius:14px;padding:32px 24px;text-align:center;height:100%;box-shadow:0 2px 12px rgba(0,0,0,0.04);">
                <div style="width:60px;height:60px;background:var(--rose);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
                    <i class="fas fa-star" style="color:var(--gold);font-size:1.4rem;"></i>
                </div>
                <h5 style="font-family:'Playfair Display',serif;margin-bottom:10px;">Curated Quality</h5>
                <p style="color:var(--mid);font-size:0.9rem;line-height:1.75;margin:0;">We don't just stock products — we curate them. Only pieces that meet our standard of quality and style make it to our collection.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div style="background:#fff;border:1px solid var(--border);border-radius:14px;padding:32px 24px;text-align:center;height:100%;box-shadow:0 2px 12px rgba(0,0,0,0.04);">
                <div style="width:60px;height:60px;background:var(--rose);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
                    <i class="fas fa-users" style="color:var(--rose-dark);font-size:1.4rem;"></i>
                </div>
                <h5 style="font-family:'Playfair Display',serif;margin-bottom:10px;">Community First</h5>
                <p style="color:var(--mid);font-size:0.9rem;line-height:1.75;margin:0;">Our customers are our family. We listen, we learn, and we grow together — because your trust is the foundation of everything we do.</p>
            </div>
        </div>
    </div>

    <!-- Divider Quote -->
    <div style="background:var(--rose);border-radius:14px;padding:36px 32px;text-align:center;margin-bottom:56px;">
        <p style="font-family:'Playfair Display',serif;font-size:clamp(1.1rem,2.5vw,1.5rem);font-style:italic;color:var(--dark);margin:0;">
            "Style is a way to say who you are without having to speak."
        </p>
        <p style="color:var(--mid);font-size:0.82rem;margin-top:10px;margin-bottom:0;letter-spacing:1px;text-transform:uppercase;">The Maayon Promise</p>
    </div>

    <!-- Connect Section -->
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <p style="font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;">Stay Connected</p>
            <h2 style="font-family:'Playfair Display',serif;font-size:clamp(1.4rem,3vw,2rem);margin-bottom:14px;">Follow Our Journey</h2>
            <p style="color:var(--mid);font-size:0.95rem;margin-bottom:28px;">
                Join our growing community on social media for the latest arrivals, style inspiration, and exclusive offers.
            </p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a href="https://www.facebook.com/share/1CY97SAYqg/" target="_blank"
                   style="display:inline-flex;align-items:center;gap:8px;padding:12px 24px;
                          background:#1877f2;color:#fff;border-radius:50px;text-decoration:none;
                          font-size:0.9rem;font-weight:500;transition:opacity 0.2s;"
                   onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
                    <i class="fab fa-facebook-f"></i> Facebook
                </a>
                <a href="https://www.instagram.com/fashionmaayon?igsh=M2x2NnVkaWkzYWk0" target="_blank"
                   style="display:inline-flex;align-items:center;gap:8px;padding:12px 24px;
                          background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);
                          color:#fff;border-radius:50px;text-decoration:none;
                          font-size:0.9rem;font-weight:500;transition:opacity 0.2s;"
                   onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
                    <i class="fab fa-instagram"></i> Instagram
                </a>
            </div>
        </div>
    </div>

</div>

<%- include('partials/footer') %>
