<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> | Maayon Fashion</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <div class="container product-detail-section">
        <div class="row">
            <!-- Product Images -->
            <div class="col-md-6">
                <div class="main-image mb-3">
                    <img src="<%= images[0]?.image_url || product.image_url %>" class="img-fluid rounded" alt="<%= product.name %>">
                </div>
                <% if (images.length > 1) { %>
                <div class="row g-2">
                    <% images.forEach(img => { %>
                        <div class="col-3">
                            <img src="<%= img.image_url %>" class="img-fluid rounded" alt="Thumbnail">
                        </div>
                    <% }) %>
                </div>
                <% } %>
            </div>
            
            <!-- Product Info -->
            <div class="col-md-6">
                <div class="product-tag"><%= product.category %></div>
                <h1 class="mb-3"><%= product.name %></h1>
                <div class="price-large mb-3">LKR <%= product.price %></div>
                <p class="text-muted mb-4"><%= product.description %></p>
                
                <a href="https://wa.me/94771234567?text=I'm%20interested%20in%20<%= encodeURIComponent(product.name) %>" 
                   class="whatsapp-order-btn" target="_blank">
                    📱 Order via WhatsApp
                </a>
                
                <hr class="my-4">
                
                <!-- Reviews Section -->
                <h3 class="detail-section-title">Customer Reviews</h3>
                <% if (reviews && reviews.length > 0) { %>
                    <% reviews.forEach(review => { %>
                        <div class="review-card">
                            <div class="d-flex align-items-center mb-2">
                                <div class="reviewer-avatar me-2">
                                    <%= review.customer_name.charAt(0).toUpperCase() %>
                                </div>
                                <strong><%= review.customer_name %></strong>
                            </div>
                            <div class="review-stars mb-2">
                                <%= '★'.repeat(review.rating) %><%= '☆'.repeat(5-review.rating) %>
                            </div>
                            <p class="review-text"><%= review.comment %></p>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p>No reviews yet. Be the first to review this product!</p>
                <% } %>
                
                <!-- Add Review Form -->
                <div class="add-review mt-4">
                    <h4>Write a Review</h4>
                    <form action="/reviews/add" method="POST">
                        <input type="hidden" name="product_id" value="<%= product.id %>">
                        <div class="mb-3">
                            <label class="form-label">Your Name</label>
                            <input type="text" name="customer_name" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Rating</label>
                            <select name="rating" class="form-control" required>
                                <option value="5">5 Stars - Excellent</option>
                                <option value="4">4 Stars - Very Good</option>
                                <option value="3">3 Stars - Good</option>
                                <option value="2">2 Stars - Fair</option>
                                <option value="1">1 Star - Poor</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Your Review</label>
                            <textarea name="comment" class="form-control" rows="3" required></textarea>
                        </div>
                        <button type="submit" class="btn-gold">Submit Review</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <%- include('partials/footer') %>
    
    <a href="/auth/login" class="admin-fab">
        <span class="lock-icon">🔒</span>
        <span>Admin</span>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>