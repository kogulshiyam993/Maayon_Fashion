<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Admin Dashboard</h1>
            <p class="text-muted">Welcome, <%= user.email %></p>
        </div>
        <a href="/auth/logout" class="btn btn-danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>

    <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- CATEGORY MANAGEMENT -->
    <div class="card mb-4">
        <div class="card-header"><h3 class="mb-0"><i class="fas fa-tags me-2"></i>Manage Categories</h3></div>
        <div class="card-body">
            <div class="row align-items-start">
                <div class="col-md-5 mb-3">
                    <form action="/admin/categories" method="POST">
                        <label class="form-label fw-bold">Add New Category</label>
                        <div class="input-group">
                            <input type="text" name="name" class="form-control" placeholder="e.g. Boys Wear" required>
                            <button type="submit" class="btn btn-gold"><i class="fas fa-plus"></i> Add</button>
                        </div>
                        <small class="text-muted">URL slug is auto-generated from the name.</small>
                    </form>
                </div>
                <div class="col-md-7">
                    <label class="form-label fw-bold">Existing Categories</label>
                    <div class="d-flex flex-wrap gap-2">
                        <% (locals.categories || []).forEach(cat => { %>
                            <span class="badge d-flex align-items-center gap-2 px-3 py-2" style="background:#d4af37;font-size:0.9rem;">
                                <%= cat.name %>
                                <button onclick="deleteCategory(<%= cat.id %>, '<%= cat.name %>')"
                                        class="btn-close btn-close-white" style="font-size:0.6rem;"></button>
                            </span>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ADD PRODUCT FORM -->
    <div class="card mb-4">
        <div class="card-header"><h3 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Add New Product</h3></div>
        <div class="card-body">
            <form action="/admin/products" method="POST" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Product Name</label>
                        <input type="text" name="name" class="form-control" placeholder="e.g. Pink Floral Dress" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Price (LKR)</label>
                        <input type="number" name="price" class="form-control" placeholder="e.g. 1500" step="0.01" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Category</label>
                        <select name="category" class="form-control" required>
                            <% (locals.categories || []).forEach(cat => { %>
                                <option value="<%= cat.slug %>"><%= cat.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- MULTIPLE IMAGE UPLOAD -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            Product Images
                            <span class="text-muted fw-normal">(select multiple — first = primary)</span>
                        </label>
                        <input type="file" name="images" id="imageInput" class="form-control"
                               accept="image/*" multiple required onchange="previewImages(this)">
                        <small class="text-muted">JPG, PNG, WEBP — max 5 MB each, up to 10 images</small>

                        <!-- Preview grid -->
                        <div id="previewGrid" class="d-flex flex-wrap gap-2 mt-3"></div>
                    </div>

                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Describe the product..." required></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-gold"><i class="fas fa-plus me-1"></i> Add Product</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- PRODUCTS LIST -->
    <div class="card">
        <div class="card-header">
            <h3 class="mb-0"><i class="fas fa-boxes me-2"></i>Manage Products
                <span class="badge bg-secondary ms-2"><%= products.length %></span>
            </h3>
        </div>
        <div class="card-body">
            <% if (products.length === 0) { %>
                <div class="text-center py-4 text-muted">
                    <i class="fas fa-box-open fa-3x mb-3"></i>
                    <p>No products yet. Add your first product above!</p>
                </div>
            <% } else { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Images</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach(product => { %>
                            <tr>
                                <td>
                                    <!-- Show all images as small thumbnails -->
                                    <div class="d-flex flex-wrap gap-1">
                                        <% const imgs = product.product_images && product.product_images.length > 0
                                            ? product.product_images.sort((a,b) => a.sort_order - b.sort_order)
                                            : [{ id: null, image_url: product.image_url, is_primary: true }]; %>
                                        <% imgs.forEach(img => { %>
                                            <div class="position-relative" style="width:50px;height:50px;">
                                                <img src="<%= img.image_url %>" width="50" height="50"
                                                     style="object-fit:cover;border-radius:6px;
                                                            border: 2px solid <%= img.is_primary ? '#d4af37' : '#ddd' %>;"
                                                     title="<%= img.is_primary ? 'Primary image' : '' %>">
                                                <% if (img.id && imgs.length > 1) { %>
                                                    <button onclick="deleteImage(<%= product.id %>, <%= img.id %>)"
                                                            class="position-absolute top-0 end-0 btn btn-danger p-0"
                                                            style="width:16px;height:16px;font-size:9px;border-radius:50%;line-height:1;"
                                                            title="Remove this image">✕</button>
                                                <% } %>
                                            </div>
                                        <% }) %>
                                    </div>
                                </td>
                                <td><strong><%= product.name %></strong></td>
                                <td><span class="badge bg-secondary"><%= product.category %></span></td>
                                <td>LKR <%= product.price %></td>
                                <td>
                                    <button class="btn btn-sm btn-danger"
                                            onclick="deleteProduct(<%= product.id %>, '<%= product.name %>')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
// Multi-image preview grid
function previewImages(input) {
    const grid = document.getElementById('previewGrid');
    grid.innerHTML = '';
    if (!input.files || input.files.length === 0) return;

    Array.from(input.files).forEach((file, idx) => {
        const reader = new FileReader();
        reader.onload = e => {
            const wrapper = document.createElement('div');
            wrapper.className = 'position-relative';
            wrapper.style.cssText = 'width:80px;height:80px;';
            wrapper.innerHTML = `
                <img src="${e.target.result}" alt="Preview"
                     style="width:80px;height:80px;object-fit:cover;border-radius:8px;
                            border:2px solid ${idx === 0 ? '#d4af37' : '#ccc'};">
                ${idx === 0 ? '<span class="position-absolute top-0 start-0 badge" style="background:#d4af37;font-size:9px;">Primary</span>' : ''}
            `;
            grid.appendChild(wrapper);
        };
        reader.readAsDataURL(file);
    });
}

async function deleteProduct(id, name) {
    if (confirm(`Delete "${name}" and all its images? This cannot be undone.`)) {
        const res = await fetch(`/admin/products/${id}`, { method: 'DELETE' });
        if (res.ok) location.reload();
        else alert('Failed to delete product.');
    }
}

async function deleteImage(productId, imageId) {
    if (confirm('Remove this image from the product?')) {
        const res = await fetch(`/admin/products/${productId}/images/${imageId}`, { method: 'DELETE' });
        if (res.ok) location.reload();
        else alert('Failed to remove image.');
    }
}

async function deleteCategory(id, name) {
    if (confirm(`Delete category "${name}"?`)) {
        const res = await fetch(`/admin/categories/${id}`, { method: 'DELETE' });
        if (res.ok) location.reload();
        else alert('Failed to delete category.');
    }
}
</script>

<%- include('../partials/footer') %>
