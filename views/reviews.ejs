<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Page Header -->
<div style="background:linear-gradient(135deg,var(--rose) 0%,#fdf6f3 100%);padding:50px 0 40px;text-align:center;">
    <div class="container">
        <p style="font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;">Our Community</p>
        <h1 style="font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);margin-bottom:10px;">Wall of Love</h1>
        <p style="color:var(--mid);font-size:0.95rem;">Words from our cherished customers who carry the Maayon legacy.</p>
    </div>
</div>

<div class="container my-5">
    <% if (reviews.length === 0) { %>
        <div class="text-center py-5">
            <i class="fas fa-heart fa-4x mb-3" style="color:var(--rose-dark);"></i>
            <h3 style="font-family:'Playfair Display',serif;color:var(--mid);">No reviews yet</h3>
            <p style="color:var(--mid);">Be the first to share your experience!</p>
            <a href="/" class="btn btn-gold mt-2">Shop Now</a>
        </div>
    <% } else { %>
        <div class="row">
            <% reviews.forEach(review => { %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="testimonial-card">
                        <div class="testimonial-content">
                            <!-- Stars -->
                            <div class="mb-2">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <i class="fas fa-star <%= i <= review.rating ? '' : 'text-muted' %>"
                                       style="color:<%= i <= review.rating ? '#f5a623' : '#ccc' %>;font-size:0.85rem;"></i>
                                <% } %>
                            </div>
                            <!-- Comment -->
                            <p class="testimonial-text">"<%= review.comment %>"</p>
                            <!-- Footer -->
                            <div class="testimonial-footer d-flex align-items-center gap-2 mt-3">
                                <div style="width:36px;height:36px;border-radius:50%;background:var(--gold);
                                            display:flex;align-items:center;justify-content:center;
                                            color:#fff;font-weight:700;font-size:0.85rem;flex-shrink:0;">
                                    <%= review.customer_name.charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <strong style="font-size:0.9rem;"><%= review.customer_name %></strong>
                                    <small class="d-block" style="color:var(--mid);font-size:0.78rem;">
                                        Reviewed: <%= review.products ? review.products.name : 'a product' %>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
