<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reviews | Maayon Fashion</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <div class="container py-5">
        <h1 class="section-title">Wall of Love</h1>
        <p class="section-subtitle">What our customers say about us</p>
        
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <% if (reviews && reviews.length > 0) { %>
                    <% reviews.forEach(review => { %>
                        <div class="testimonial-card mb-4">
                            <div class="testimonial-content">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="reviewer-avatar me-3">
                                        <%= review.customer_name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                        <strong class="d-block"><%= review.customer_name %></strong>
                                        <div class="review-stars">
                                            <%= '★'.repeat(review.rating) %><%= '☆'.repeat(5-review.rating) %>
                                        </div>
                                    </div>
                                </div>
                                <p class="testimonial-text"><%= review.comment %></p>
                                <small class="text-muted">Reviewed on <%= new Date(review.created_at).toLocaleDateString() %></small>
                                <% if (review.products) { %>
                                    <div class="mt-2">
                                        <small class="text-muted">Product: <strong><%= review.products.name %></strong></small>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-5">
                        <h3>No reviews yet</h3>
                        <p>Be the first to share your experience with us!</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    
    <%- include('partials/footer') %>
    
    <a href="/auth/login" class="admin-fab">
        <span class="lock-icon">🔒</span>
        <span>Admin</span>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>